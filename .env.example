# ============================================================
# GLOBAL .NET SETTINGS
# ============================================================
DOTNET_CONFIGURATION=Release
ASPNETCORE_ENVIRONMENT=Production

# ============================================================
# JWT
# ============================================================
JWT_SECRET=
JWT_ISSUER=
JWT_AUDIENCE=

# ============================================================
# POSTGRES
# POSTGRES_USER      → superuser used just in the initialization (P01)
# PONTUEI_PASSWORD   → password of the 'pontuei' user (P02 onwards)
# DB_CONNECTIONSTRING → complete connection string used by the API
# ============================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=pontuei
PONTUEI_PASSWORD=
DB_CONNECTIONSTRING=Host=pontuei-db;Port=5432;Database=pontuei;Username=pontuei;Password=

# ============================================================
# REDIS
# REDIS_CONNECTIONSTRING → used by the API (StackExchange.Redis format)
# ============================================================
REDIS_PASSWORD=
REDIS_CONNECTIONSTRING=pontuei-redis:6379,password=

# ============================================================
# MINIO (Object Storage)
# MINIO_ENDPOINT      → used by the API to build URLs for the files
# MINIO_BUCKET_MEDIA  → private bucket for media files of transactions
# MINIO_BUCKET_PROGRAMS → public bucket for program logos
# ============================================================
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_ENDPOINT=http://pontuei-minio:9000
MINIO_BUCKET_MEDIA=pontuei-media
MINIO_BUCKET_PROGRAMS=pontuei-programs

# ============================================================
# SEQ (Logging)
# SEQ_URL → usado pelo Serilog na API
# ============================================================
SEQ_URL=http://pontuei-seq:5341
SEQ_FIRSTRUN_ADMINPASSWORD=

# ============================================================
# EMAIL
# ============================================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=seu-email@gmail.com
EMAIL_PASSWORD=sua-senha-de-app
EMAIL_FROM=seu-email@gmail.com

# ============================================================
# FIREBASE (SSO Google + Push Notifications FCM) [base64-encoded]
# ============================================================
FIREBASE_CREDENTIALS_BASE64= eyJ0eXBlIjogInNlcnZpY2VfYWNjb3VudCIs...

# ============================================================
# API Admin User Credentials
# ============================================================
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ============================================================
# MOBILE APP CONFIGURATIONS (.NET MAUI)
# ============================================================
# If you are running the official Android Emulator, use 10.0.2.2 instead of localhost
MAUI_API_BASE_URL=
MAUI_STORAGE_BASE_URL=
MAUI_GOOGLE_WEB_CLIENT_ID=seu_client_id_do_google_aqui.apps.googleusercontent.com
# Firebase configuration for the mobile app (base64-encoded)
GOOGLE_SERVICES_BASE64=eyJ0eXBlIjogInNlcnZpY2VfYWNjb3VudCIs...
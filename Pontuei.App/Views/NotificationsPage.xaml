<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage
    x:Class="Pontuei.App.Views.NotificationsPage"
    x:DataType="local:NotificationsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Pontuei.App.Views"
    xmlns:local="clr-namespace:Pontuei.App.Views"
    xmlns:controls="clr-namespace:Pontuei.App.Controls"
    Shell.NavBarIsVisible="False"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="#EDE8E8">

        <!-- CONTEÚDO ROLÁVEL -->
        <ScrollView VerticalScrollBarVisibility="Never"
                    Padding="0,0,0,110">

            <VerticalStackLayout Spacing="0">

                <!-- HEADER -->
                <Grid Padding="28,56,28,24"
                      ColumnDefinitions="Auto, *, Auto">
 
                    <!-- Logo -->
                    <Image Grid.Column="0"
                           Source="logo.svg"
                           HeightRequest="48"
                           WidthRequest="80"
                           HorizontalOptions="Start"
                           VerticalOptions="Center"
                           Aspect="AspectFit" />

                    <!-- Settings -->
                    <Border Grid.Column="2"
                            WidthRequest="40"
                            HeightRequest="40"
                            BackgroundColor="Transparent"
                            StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSettingsTapped" />
                        </Border.GestureRecognizers>
                        <Image Source="settings.svg"
                               WidthRequest="24"
                               HeightRequest="24"
                               Aspect="AspectFit"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                </Grid>

<!-- TÍTULO DA SEÇÃO -->
                <Label Text="Notificações"
                       Margin="24,0,24,0"
                       TextColor="#1A1A1A"
                       FontFamily="PoppinsSemibold"
                       FontAttributes="Bold"
                       FontSize="22" />

                <!-- SEPARADOR -->
                <BoxView HeightRequest="1"
                         Color="#D0C8C8"
                         Margin="24,12,24,16" />

<!-- LISTA DE NOTIFICAÇÕES -->
                <VerticalStackLayout x:Name="NotificationsList"
                                     BindableLayout.ItemsSource="{Binding Notifications}"
                                     Spacing="0">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="local:NotificationItem">
                            <Grid Margin="24,0,24,12">
                                <!-- Card principal com a opacidade baseada no status de leitura -->
                                <Border BackgroundColor="White"
                                        StrokeThickness="0"
                                        Opacity="{Binding CardOpacity}"
                                        Padding="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="16" />
                                    </Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.08" />
                                    </Border.Shadow>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnNotificationTapped"
                                                              CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>

                                    <!-- Padding vertical reduzido para 10 para deixar o card mais estreito -->
                                    <Grid ColumnDefinitions="*, Auto"
                                          Padding="16,10,16,10"
                                          RowDefinitions="Auto, *">

                                        <!-- Texto da notificação (agora na Column 0, já que a bolinha sumiu) -->
                                        <Label Grid.Column="0"
                                               Grid.Row="0"
                                               Grid.RowSpan="2"
                                               Text="{Binding Message}"
                                               TextColor="#1A1A1A"
                                               FontFamily="PoppinsRegular"
                                               FontSize="13"
                                               LineHeight="1.4"
                                               VerticalOptions="Center"
                                               Margin="0,0,12,0" />

                                        <!-- Pontos -->
                                        <Label Grid.Column="1"
                                               Grid.Row="0"
                                               Text="{Binding FormattedPoints}"
                                               TextColor="#1A1A1A"
                                               FontFamily="PoppinsSemibold"
                                               FontAttributes="Bold"
                                               FontSize="14"
                                               HorizontalOptions="End"
                                               VerticalOptions="Start" />

                                        <!-- Data -->
                                        <Label Grid.Column="1"
                                               Grid.Row="1"
                                               Text="{Binding FormattedDate}"
                                               TextColor="#9E9E9E"
                                               FontFamily="PoppinsRegular"
                                               FontSize="11"
                                               HorizontalOptions="End"
                                               VerticalOptions="End"
                                               Margin="0,2,0,0" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
                                
                <!-- ESTADO VAZIO -->
                <VerticalStackLayout x:Name="EmptyState"
                                     IsVisible="{Binding HasNoNotifications}"
                                     HorizontalOptions="Center"
                                     Margin="0,48,0,0"
                                     Spacing="12">
                    <Image Source="bell.svg"
                           WidthRequest="48"
                           HeightRequest="48"
                           Aspect="AspectFit"
                           Opacity="0.3"
                           HorizontalOptions="Center" />
                    <Label Text="Nenhuma notificação"
                           TextColor="#9E9E9E"
                           FontFamily="PoppinsRegular"
                           FontSize="15"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- SEPARADOR INFERIOR -->
                <BoxView HeightRequest="1"
                         Color="#D0C8C8"
                         Margin="24,8,24,0"
                         IsVisible="{Binding HasNotifications}" />

                <!-- MARCAR TODAS COMO LIDAS -->
                <Label Text="Marcar todas as notificações como lidas"
                       TextColor="#9E9E9E"
                       FontFamily="PoppinsRegular"
                       FontSize="14"
                       HorizontalOptions="Center"
                       Margin="0,14,0,24"
                       IsVisible="{Binding HasUnread}">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnMarkAllReadTapped" />
                    </Label.GestureRecognizers>
                </Label>

            </VerticalStackLayout>
        </ScrollView>

        <!-- NAVBAR -->
</views:BasePage>

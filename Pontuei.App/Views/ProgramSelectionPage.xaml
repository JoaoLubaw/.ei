<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Pontuei.App.Views.ProgramSelectionPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Pontuei.App.Views"
    xmlns:dtos="clr-namespace:Pontuei.Shared.Dtos.Objects;assembly=Pontuei.Shared"
    xmlns:ffimageloading="clr-namespace:FFImageLoading.Maui;assembly=FFImageLoading.Maui"
    Shell.NavBarIsVisible="False"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="#000000">

    <!-- Grid principal separando o fundo preto do cartão bege -->
    <Grid RowDefinitions="Auto, *">
        <Border
            Grid.Row="1" 
            BackgroundColor="#E9E2E2"
            StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="32,32,0,0" />
            </Border.StrokeShape>

            <!-- Grid de conteúdo: Header(0), Lista(1), Botão(2) -->
            <Grid RowDefinitions="Auto, *, Auto" Padding="28,24,28,28">

                <!-- HEADER -->
                <VerticalStackLayout Grid.Row="0" Spacing="6" Margin="0,0,0,20">
                    <ffimageloading:CachedImage Source="logo.svg" HeightRequest="60" HorizontalOptions="End" Aspect="AspectFit" />
                    <VerticalStackLayout Spacing="6" IsVisible="{Binding IsHeaderVisible}">
                        <Label Text="{Binding HeaderEyebrow}" TextColor="#6B6B6B" FontSize="18" FontFamily="PoppinsRegular" />
                        <Label Text="{Binding HeaderTitle}" 
                               TextColor="#000000" FontSize="22" LineHeight="1.2" />
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- SCROLLVIEW COM A LISTA (com overlay de carregamento) -->
                <Grid Grid.Row="1">
                    <ActivityIndicator IsRunning="{Binding IsLoading}"
                                       IsVisible="{Binding IsLoading}"
                                       Color="#3A6B4A"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center" />

                    <ScrollView VerticalScrollBarVisibility="Never"
                                IsVisible="{Binding IsNotLoading}">
                    <VerticalStackLayout Spacing="12">
                        <CollectionView x:Name="ProgramsCollectionView"
                                        SelectionMode="None"
                                        ItemsSource="{Binding ProgramItems}"
                                        VerticalOptions="Start"
                                        VerticalScrollBarVisibility="Never">
                            <CollectionView.ItemsLayout>
                                <GridItemsLayout
                                    Orientation="Vertical"
                                    Span="3"
                                    VerticalItemSpacing="12"
                                    HorizontalItemSpacing="12" />
                            </CollectionView.ItemsLayout>

                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="local:ProgramSelectItem">
                                    <Border
                                        x:Name="ProgramBorder"
                                        HeightRequest="84"
                                        BackgroundColor="White"
                                        StrokeShape="RoundRectangle 16"
                                        StrokeThickness="2"
                                        Stroke="Transparent">

                                        <!-- Destaque de seleção via DataTrigger: reflete IsSelected
                                             automaticamente, inclusive quando o item já vem
                                             pré-selecionado pela navegação (filtro), sem depender
                                             de um toque para colorir a borda. -->
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Stroke" Value="#3A6B4A" />
                                            </DataTrigger>
                                        </Border.Triggers>

                                        <Border.GestureRecognizers>
                                            <!-- CommandParameter passa o próprio Border para o handler -->
                                            <TapGestureRecognizer
                                                Tapped="OnProgramTapped"
                                                CommandParameter="{x:Reference ProgramBorder}" />
                                        </Border.GestureRecognizers>

                                        <ffimageloading:CachedImage
                                            Source="{Binding LogoUrl}"
                                            Aspect="AspectFit"
                                            Margin="14"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center"
                                            InputTransparent="True" />
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <!-- OUTRO -->
                        <Border
                            x:Name="OtherOptionBorder"
                            HeightRequest="84"
                            BackgroundColor="White"
                            StrokeShape="RoundRectangle 16"
                            StrokeThickness="2"
                            Stroke="Transparent">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnOtherTapped" />
                            </Border.GestureRecognizers>
                            <Label
                                Text="{Binding OtherOptionLabel}"
                                TextColor="#1A1A1A"
                                FontFamily="PoppinsSemibold"
                                FontAttributes="Bold"
                                FontSize="18"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        </Border>
                    </VerticalStackLayout>
                    </ScrollView>
                </Grid>

                <!-- CONTINUAR -->
                <Button
                    Grid.Row="2"
                    x:Name="ContinueButton"
                    Text="{Binding ContinueButtonText}"
                    FontFamily="PoppinsBold"
                    FontAttributes="Bold"
                    FontSize="16"
                    TextColor="White"
                    BackgroundColor="#3f3838"
                    CornerRadius="26"
                    HeightRequest="52"
                    Margin="0,20,0,0"
                    Clicked="OnContinueClicked"
                    IsEnabled="False" />

            </Grid>
        </Border>
    </Grid>
</ContentPage>
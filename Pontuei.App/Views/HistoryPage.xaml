<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Pontuei.App.Views.HistoryPage"
             xmlns:views="clr-namespace:Pontuei.App.Views"
             xmlns:local="clr-namespace:Pontuei.App.Views"
             xmlns:ffimageloading="clr-namespace:FFImageLoading.Maui;assembly=FFImageLoading.Maui"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#EDE8E8">

    <Grid>
        <!-- LOADING OVERLAY -->
        <ActivityIndicator IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           Color="#3A6B4A"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           ZIndex="10" />

        <ScrollView VerticalScrollBarVisibility="Never" 
                    Padding="0,0,0,110"
                    IsVisible="{Binding IsNotLoading}">
                    
            <VerticalStackLayout Spacing="0">

                <Label Text="Histórico de transações confirmadas:"
                       Margin="24,0,24,12" TextColor="#1A1A1A" FontFamily="PoppinsSemibold"
                       FontAttributes="Bold" FontSize="18" />

                <Grid ColumnDefinitions="*, Auto" Margin="24,0,24,16">
                    
                    <!-- FILTROS DE STATUS (bolinhas coloridas que expandem ao tocar) -->
                    <ScrollView Grid.Column="0" Orientation="Horizontal" HorizontalScrollBarVisibility="Never" VerticalOptions="Center">
                        <HorizontalStackLayout Spacing="8" 
                                               BindableLayout.ItemsSource="{Binding Filters}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="local:StatusFilterItem">
                                    <!-- Começa como um círculo de 24 (a "bolinha"); o código-behind
                                         anima a largura até 115 e revela o Label ao ser selecionado -->
                                    <Border WidthRequest="24"
                                            HeightRequest="24"
                                            Padding="0"
                                            StrokeThickness="0"
                                            BackgroundColor="{Binding Color}"
                                            VerticalOptions="Center"
                                            HorizontalOptions="Start">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12" />
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnFilterTapped"
                                                                  CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>

                                        <!-- Texto do status, oculto até a bolinha ser tocada/expandida -->
                                        <Label Text="{Binding Name}"
                                               TextColor="White"
                                               FontFamily="PoppinsSemibold"
                                               FontSize="11"
                                               IsVisible="False"
                                               Opacity="0"
                                               Margin="10,0,10,0"
                                               VerticalOptions="Center"
                                               HorizontalOptions="Center"
                                               LineBreakMode="NoWrap" />
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </ScrollView>

                    <!-- PROGRAM SWITCHER ATUALIZADO (Degradê e Logo dinâmicos) -->
                    <Border Grid.Column="1" HeightRequest="24" StrokeThickness="0" VerticalOptions="Center" Margin="12,0,0,0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="{Binding SelectedProgramSecondaryColor}" Offset="0.0" />
                                <GradientStop Color="{Binding SelectedProgramPrimaryColor}" Offset="0.5" />
                                <GradientStop Color="{Binding SelectedProgramSecondaryColor}" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnChangeProgramTapped" />
                        </Border.GestureRecognizers>
                        
                        <HorizontalStackLayout Padding="12,0" Spacing="6" VerticalOptions="Center">
                            
                            <!-- Logo do programa (aparece se houver logo) -->
                            <ffimageloading:CachedImage 
                                Source="{Binding SelectedProgramLogo}" 
                                HeightRequest="14" 
                                WidthRequest="40"
                                Aspect="AspectFit" 
                                VerticalOptions="Center" 
                                IsVisible="{Binding HasProgramLogo}" />
                            
                            <!-- Nome do programa (fallback se não tiver logo, ou padrão 'Todos') -->
                            <Label Text="{Binding SelectedProgramName}" 
                                   TextColor="White" FontSize="11" 
                                   FontFamily="PoppinsSemibold" VerticalOptions="Center" 
                                   IsVisible="{Binding ShowProgramName}" />
                            
                            <Image Source="change.svg" WidthRequest="14" HeightRequest="14" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </Border>
                </Grid>

                <!-- LISTA DE TRANSAÇÕES -->
                <CollectionView ItemsSource="{Binding Transactions}"
                                SelectionMode="None"
                                Margin="24,0,24,0"
                                VerticalOptions="Start">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="local:HistoryTransactionItem">
                            <!-- A cor da borda representa o status (atrasada/recebida/padrão) -->
                            <Border Stroke="{Binding StatusColor}"
                                    StrokeThickness="2"
                                    BackgroundColor="White"
                                    Padding="16,12">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12" />
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnTransactionTapped"
                                                          CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>

                                <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto" RowSpacing="4">

                                    <Label Grid.Row="0" Grid.Column="0"
                                           Text="{Binding Description}"
                                           FontFamily="PoppinsSemibold"
                                           FontAttributes="Bold"
                                           FontSize="15"
                                           TextColor="#1A1A1A"
                                           LineBreakMode="TailTruncation" />

                                    <Label Grid.Row="1" Grid.Column="0"
                                           Text="{Binding Store}"
                                           FontFamily="PoppinsRegular"
                                           FontSize="12"
                                           TextColor="#6B6B6B" />

                                    <Label Grid.Row="0" Grid.Column="1"
                                           Text="{Binding FormattedPoints}"
                                           FontFamily="PoppinsSemibold"
                                           FontSize="14"
                                           TextColor="#3A6B4A"
                                           HorizontalOptions="End" />

                                    <VerticalStackLayout Grid.Row="1" Grid.Column="1"
                                                         HorizontalOptions="End"
                                                         Spacing="0">
                                        <Label Text="{Binding FormattedExpected}"
                                               FontSize="10"
                                               TextColor="#6B6B6B"
                                               HorizontalOptions="End" />
                                        <Label Text="{Binding FormattedReceived}"
                                               FontSize="10"
                                               TextColor="#6B6B6B"
                                               HorizontalOptions="End"
                                               IsVisible="{Binding HasReceivedDate}" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- LINK PARA TRANSAÇÕES PENDENTES -->
                <Label Text="Ver transações aguardadas"
                       FontFamily="PoppinsRegular"
                       FontSize="12"
                       TextColor="#6B6B6B"
                       TextDecorations="Underline"
                       HorizontalOptions="Center"
                       Margin="0,20,0,0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnViewPendingTapped" />
                    </Label.GestureRecognizers>
                </Label>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</views:BasePage>
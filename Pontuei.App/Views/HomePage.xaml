<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Pontuei.App.Views.HomePage"
             xmlns:views="clr-namespace:Pontuei.App.Views"
             xmlns:local="clr-namespace:Pontuei.App.Views"
             xmlns:controls="clr-namespace:Pontuei.App.Controls"
             xmlns:ffimageloading="clr-namespace:FFImageLoading.Maui;assembly=FFImageLoading.Maui"
             xmlns:cards="clr-namespace:PanCardView;assembly=PanCardView"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#EDE8E8">

    <!-- Overlay de carregamento — visível enquanto IsLoading=True -->
    <Grid>
    <ActivityIndicator IsRunning="{Binding IsLoading}"
                       IsVisible="{Binding IsLoading}"
                       Color="#3A6B4A"
                       VerticalOptions="Center"
                       HorizontalOptions="Center"
                       ZIndex="10" />

    <ScrollView VerticalScrollBarVisibility="Never"
                Padding="0,0,0,0"
                IsVisible="{Binding IsNotLoading}">

        <VerticalStackLayout Spacing="0">

            <!-- ── CAROUSEL DE CARDS ──────────────────────────────────── -->
            <cards:CardsView
                x:Name="ProgramsCarousel"
                ItemsSource="{Binding Cards}"
                Margin="24,0,24,0"
                HeightRequest="260"
                IsCyclical="True"
                ItemSwiped="OnCardSwiped">

                <cards:CardsView.ItemTemplate>
                    <DataTemplate x:DataType="local:DashboardCardItem">
                        <ContentView Padding="0,10,0,20">
                            <Border HeightRequest="200"
                                    StrokeThickness="0"
                                    Padding="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="24" />
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,12" Radius="15" Opacity="0.3" />
                                </Border.Shadow>

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnCardTapped" />
                                </Border.GestureRecognizers>

                                <AbsoluteLayout>
                                    <Border AbsoluteLayout.LayoutFlags="All"
                                            AbsoluteLayout.LayoutBounds="0,0,1,1"
                                            StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="24" />
                                        </Border.StrokeShape>
                                        <Border.Background>
                                            <RadialGradientBrush Center="0.5,0.5" Radius="0.85">
                                                <GradientStop Color="{Binding SecondaryColor}" Offset="0.0" />
                                                <GradientStop Color="{Binding PrimaryColor}" Offset="1.0" />
                                            </RadialGradientBrush>
                                        </Border.Background>
                                    </Border>

                                    <!-- Conteúdo do card -->
                                        <Grid AbsoluteLayout.LayoutFlags="All"
                                            AbsoluteLayout.LayoutBounds="0,0,1,1"
                                            Padding="24,20"
                                            RowDefinitions="Auto, *, Auto">

                                            <!-- Row 0: botão olho -->
                                            <Border Grid.Row="0"
                                                    HorizontalOptions="End"
                                                    VerticalOptions="Start"
                                                    WidthRequest="36"
                                                    HeightRequest="36"
                                                    BackgroundColor="#33FFFFFF"
                                                    StrokeThickness="0">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="18" />
                                                </Border.StrokeShape>
                                                <Grid>
                                                    <Image Source="eye.svg"
                                                        WidthRequest="18"
                                                        HeightRequest="18"
                                                        Aspect="AspectFit"
                                                        HorizontalOptions="Center"
                                                        VerticalOptions="Center"
                                                        IsVisible="{Binding IsEyeOpenVisible}" />
                                                    <Image Source="eye_crossed.svg"
                                                        WidthRequest="18"
                                                        HeightRequest="18"
                                                        Aspect="AspectFit"
                                                        HorizontalOptions="Center"
                                                        VerticalOptions="Center"
                                                        IsVisible="{Binding IsEyeClosedVisible}" />
                                                </Grid>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnToggleVisibilityTapped" />
                                                </Border.GestureRecognizers>
                                            </Border>

                                            <!-- Row 1: pontos -->
                                            <VerticalStackLayout Grid.Row="1"
                                                                VerticalOptions="Center"
                                                                HorizontalOptions="Center"
                                                                Spacing="2">
                                                <Label Text="{Binding FormattedPoints}"
                                                    TextColor="White"
                                                    FontFamily="BricolageGrotesqueBold"
                                                    FontAttributes="Bold"
                                                    FontSize="42"
                                                    HorizontalOptions="Center" />
                                                <Label Text="Pontos a receber"
                                                    TextColor="#DDFFFFFF"
                                                    FontFamily="PoppinsRegular"
                                                    FontSize="14"
                                                    HorizontalOptions="Center" />
                                            </VerticalStackLayout>

                                            <!-- Row 2: logo ou nome -->
                                            <Grid Grid.Row="2" VerticalOptions="End">
                                                <ffimageloading:CachedImage
                                                    Source="{Binding LogoUrl}"
                                                    HeightRequest="32"
                                                    WidthRequest="90"
                                                    Aspect="AspectFit"
                                                    HorizontalOptions="Center"
                                                    VerticalOptions="End"
                                                    IsVisible="{Binding HasLogo}" />
                                                <Label Text="{Binding ProgramName}"
                                                    TextColor="White"
                                                    FontFamily="PoppinsSemibold"
                                                    FontAttributes="Bold"
                                                    FontSize="16"
                                                    HorizontalOptions="Center"
                                                    VerticalOptions="End"
                                                    IsVisible="{Binding ShowProgramName}" />
                                            </Grid>

                                        </Grid>
                                    </AbsoluteLayout>
                            </Border>
                        </ContentView>
                    </DataTemplate>
                </cards:CardsView.ItemTemplate>
            </cards:CardsView>

            <!-- ── BLOCO DE TRANSAÇÕES ────────────────────────────────── -->
            <VerticalStackLayout Spacing="0">

                <!-- Arredondamento topo -->
                <Border BackgroundColor="Transparent" StrokeThickness="0" HeightRequest="32">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="32,32,0,0" />
                    </Border.StrokeShape>
                </Border>

                <Label x:Name="ExpectedCountLabel"
                       Text="Transações esperadas:"
                       Margin="28,0,28,16"
                       TextColor="#1A1A1A"
                       FontFamily="PoppinsSemibold"
                       FontAttributes="Bold"
                       FontSize="18" />

                <!-- Lista simples (programas individuais) -->
                <VerticalStackLayout x:Name="TransactionsList"
                                     BindableLayout.ItemsSource="{Binding CurrentTransactions}"
                                     IsVisible="{Binding HasSimpleList}"
                                     Spacing="0">

                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="local:DashboardTransactionItem">
                            <Grid Margin="24,0,24,12">
                                <!-- [ALTERADO] TapGestureRecognizer no Grid raiz para capturar toque em toda a área -->
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnTransactionTapped"
                                                          CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>
                                <Border BackgroundColor="White"
                                        Stroke="{Binding OverdueBorderColor}"
                                        StrokeThickness="{Binding OverdueThickness}"
                                        Padding="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="16" />
                                    </Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.1" />
                                    </Border.Shadow>
                                    <Grid Padding="16,14,16,14"
                                          ColumnDefinitions="*, Auto"
                                          RowDefinitions="Auto, Auto">
                                        <Label Grid.Row="0" Grid.Column="0"
                                               Text="{Binding Description}"
                                               TextColor="#1A1A1A"
                                               FontFamily="PoppinsSemibold"
                                               FontAttributes="Bold"
                                               FontSize="15" />
                                        <Label Grid.Row="0" Grid.Column="1"
                                               Text="{Binding FormattedPoints}"
                                               TextColor="#1A1A1A"
                                               FontFamily="PoppinsSemibold"
                                               FontAttributes="Bold"
                                               FontSize="14"
                                               HorizontalOptions="End" />
                                        <Label Grid.Row="1" Grid.Column="0"
                                               Text="{Binding StoreDisplay}"
                                               TextColor="#6B6B6B"
                                               FontFamily="PoppinsRegular"
                                               FontSize="13"
                                               Margin="0,4,0,0" />
                                        <Label Grid.Row="1" Grid.Column="1"
                                               Text="{Binding FormattedDate}"
                                               TextColor="#9E9E9E"
                                               FontFamily="PoppinsRegular"
                                               FontSize="12"
                                               HorizontalOptions="End"
                                               Margin="0,4,0,0" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <!-- Lista agrupada (card Outros) -->
                <VerticalStackLayout x:Name="GroupedTransactionsList"
                                     BindableLayout.ItemsSource="{Binding CurrentGroups}"
                                     IsVisible="{Binding HasGroups}"
                                     Spacing="0">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="local:DashboardTransactionGroup">
                            <VerticalStackLayout Spacing="0">
                                <Label Text="{Binding GroupName}"
                                       Margin="28,8,28,8"
                                       TextColor="#6B6B6B"
                                       FontFamily="PoppinsSemibold"
                                       FontSize="13" />
                                <BoxView HeightRequest="1" Color="#E0D8D8" Margin="24,0,24,8" />

                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Transactions}"
                                                     Spacing="0">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="local:DashboardTransactionItem">
                                            <Grid Margin="24,0,24,12">
                                                <!-- [ALTERADO] mesmo gesto no template agrupado -->
                                                <Grid.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnTransactionTapped"
                                                                          CommandParameter="{Binding .}" />
                                                </Grid.GestureRecognizers>
                                                <Border BackgroundColor="White"
                                                        Stroke="{Binding OverdueBorderColor}"
                                                        StrokeThickness="{Binding OverdueThickness}"
                                                        Padding="0">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="16" />
                                                    </Border.StrokeShape>
                                                    <Border.Shadow>
                                                        <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.1" />
                                                    </Border.Shadow>
                                                    <Grid Padding="16,14,16,14"
                                                          ColumnDefinitions="*, Auto"
                                                          RowDefinitions="Auto, Auto">
                                                        <Label Grid.Row="0" Grid.Column="0"
                                                               Text="{Binding Description}"
                                                               TextColor="#1A1A1A"
                                                               FontFamily="PoppinsSemibold"
                                                               FontAttributes="Bold"
                                                               FontSize="15" />
                                                        <Label Grid.Row="0" Grid.Column="1"
                                                               Text="{Binding FormattedPoints}"
                                                               TextColor="#1A1A1A"
                                                               FontFamily="PoppinsSemibold"
                                                               FontAttributes="Bold"
                                                               FontSize="14"
                                                               HorizontalOptions="End" />
                                                        <Label Grid.Row="1" Grid.Column="0"
                                                               Text="{Binding StoreDisplay}"
                                                               TextColor="#6B6B6B"
                                                               FontFamily="PoppinsRegular"
                                                               FontSize="13"
                                                               Margin="0,4,0,0" />
                                                        <Label Grid.Row="1" Grid.Column="1"
                                                               Text="{Binding FormattedDate}"
                                                               TextColor="#9E9E9E"
                                                               FontFamily="PoppinsRegular"
                                                               FontSize="12"
                                                               HorizontalOptions="End"
                                                               Margin="0,4,0,0" />
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <!-- Separador e link de histórico -->
                <BoxView HeightRequest="1" Color="#E0D8D8" Margin="24,12,24,12" />
                <Label Text="Ver transações passadas"
                       TextColor="#6B6B6B"
                       FontFamily="PoppinsRegular"
                       FontSize="14"
                       HorizontalOptions="Center"
                       Margin="0,0,0,24">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnViewPastTransactionsTapped" />
                    </Label.GestureRecognizers>
                </Label>

            </VerticalStackLayout>
            <!-- ── FIM BLOCO DE TRANSAÇÕES ────────────────────────────── -->

        </VerticalStackLayout>
    </ScrollView>
    </Grid>

</views:BasePage>

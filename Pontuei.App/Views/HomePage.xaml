<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Pontuei.App.Views.HomePage"
    x:DataType="local:HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Pontuei.App.Views"
    xmlns:controls="clr-namespace:Pontuei.App.Controls"
    xmlns:ffimageloading="clr-namespace:FFImageLoading.Maui;assembly=FFImageLoading.Maui"
    xmlns:cards="clr-namespace:PanCardView;assembly=PanCardView"
    Shell.NavBarIsVisible="False"
    NavigationPage.HasNavigationBar="False"
    BackgroundColor="#EDE8E8">

    <Grid RowDefinitions="*, Auto">

        <!-- SCROLLABLE CONTENT -->
            <ScrollView Grid.Row="0" 
                Grid.RowSpan="2" 
                VerticalScrollBarVisibility="Never" 
                Padding="0,0,0,110">
                    
            <VerticalStackLayout Spacing="0">

                <!-- HEADER -->
                <Grid
                    Padding="28,56,28,24"
                    ColumnDefinitions="*, Auto, Auto">

                    <Image
                        Grid.Column="0"
                        Source="logo.svg"
                        HeightRequest="48"
                        WidthRequest="80"
                        HorizontalOptions="Start"
                        VerticalOptions="Center"
                        Aspect="AspectFit" />

                    <Border
                        Grid.Column="2"
                        WidthRequest="40"
                        HeightRequest="40"
                        BackgroundColor="Transparent"
                        StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <Image
                            Source="settings.svg"
                            WidthRequest="24"
                            HeightRequest="24"
                            Aspect="AspectFit"
                            HorizontalOptions="Center"
                            VerticalOptions="Center" />
                    </Border>
                </Grid>

                <!-- STACKED CARDS AREA COM CARDSVIEW -->
                <cards:CardsView
                    x:Name="ProgramsCarousel"
                    ItemsSource="{Binding Cards}"
                    Margin="24,0,24,0"
                    HeightRequest="260"
                    IsCyclical="True"
                    ItemSwiped="OnCardSwiped">
                    <cards:CardsView.ItemTemplate>
                        <!-- CARD TEMPLATE CORRIGIDO -->
                        <!-- Substitui o DataTemplate dentro de cards:CardsView.ItemTemplate -->
                        <DataTemplate x:DataType="local:DashboardCardItem">

                            <ContentView Padding="0,10,0,20">
                                <Border
                                    HeightRequest="200"
                                    StrokeThickness="0"
                                    Padding="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="24" />
                                    </Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="Black" Offset="0,12" Radius="15" Opacity="0.3" />
                                    </Border.Shadow>

                                    <!-- 
                                        GRADIENTE RADIAL SIMULADO:
                                        Usamos um AbsoluteLayout com dois LinearGradients empilhados:
                                        1) Horizontal: primária→secundária→primária  (bordas laterais)
                                        2) Vertical com blending: dá o efeito de "bordas superior/inferior" também escuras
                                        O resultado visual é: centro claro (secundária), todas as bordas escuras (primária)
                                    -->
                                    <AbsoluteLayout>

                                        <!-- Camada 1: gradiente horizontal (esquerda/direita) -->
                                        <Border
                                            AbsoluteLayout.LayoutFlags="All"
                                            AbsoluteLayout.LayoutBounds="0,0,1,1"
                                            StrokeThickness="0">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="24" />
                                            </Border.StrokeShape>
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                    <GradientStop Color="{Binding PrimaryColor}" Offset="0.0" />
                                                    <GradientStop Color="{Binding SecondaryColor}" Offset="0.5" />
                                                    <GradientStop Color="{Binding PrimaryColor}" Offset="1.0" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <BoxView BackgroundColor="Transparent" />
                                        </Border>

                                        <!-- Camada 2: gradiente vertical (cima/baixo) com blending escurecido nas bordas -->
                                        <!-- Usa cor preta semi-transparente nas extremidades para simular o "vinheta" radial -->
                                        <Border
                                            AbsoluteLayout.LayoutFlags="All"
                                            AbsoluteLayout.LayoutBounds="0,0,1,1"
                                            StrokeThickness="0">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="24" />
                                            </Border.StrokeShape>
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                    <GradientStop Color="#55000000" Offset="0.0" />
                                                    <GradientStop Color="#00000000" Offset="0.35" />
                                                    <GradientStop Color="#00000000" Offset="0.65" />
                                                    <GradientStop Color="#55000000" Offset="1.0" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <BoxView BackgroundColor="Transparent" />
                                        </Border>

                                        <!-- CONTEÚDO DO CARD -->
                                        <Grid
                                            AbsoluteLayout.LayoutFlags="All"
                                            AbsoluteLayout.LayoutBounds="0,0,1,1"
                                            Padding="24,20"
                                            RowDefinitions="Auto, *, Auto">

                                            <!-- Row 0: Botão de olho no topo direito -->
                                            <Border
                                                Grid.Row="0"
                                                HorizontalOptions="End"
                                                VerticalOptions="Start"
                                                WidthRequest="36"
                                                HeightRequest="36"
                                                BackgroundColor="#33FFFFFF"
                                                StrokeThickness="0">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="18" />
                                                </Border.StrokeShape>
                                                <Grid>
                                                    <Image
                                                        Source="eye.svg"
                                                        WidthRequest="18"
                                                        HeightRequest="18"
                                                        Aspect="AspectFit"
                                                        HorizontalOptions="Center"
                                                        VerticalOptions="Center"
                                                        IsVisible="{Binding IsEyeOpenVisible}" />
                                                    <Image
                                                        Source="eye_crossed.svg"
                                                        WidthRequest="18"
                                                        HeightRequest="18"
                                                        Aspect="AspectFit"
                                                        HorizontalOptions="Center"
                                                        VerticalOptions="Center"
                                                        IsVisible="{Binding IsEyeClosedVisible}" />
                                                </Grid>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnToggleVisibilityTapped" />
                                                </Border.GestureRecognizers>
                                            </Border>

                                            <!-- Row 1: Pontos centralizados (horizontal e vertical) -->
                                            <VerticalStackLayout
                                                Grid.Row="1"
                                                VerticalOptions="Center"
                                                HorizontalOptions="Center"
                                                Spacing="2">
                                                <Label
                                                    Text="{Binding FormattedPoints}"
                                                    TextColor="White"
                                                    FontFamily="BricolageGrotesqueBold"
                                                    FontAttributes="Bold"
                                                    FontSize="42"
                                                    HorizontalOptions="Center" />
                                                <Label
                                                    Text="Pontos a receber"
                                                    TextColor="#DDFFFFFF"
                                                    FontFamily="PoppinsRegular"
                                                    FontSize="14"
                                                    HorizontalOptions="Center" />
                                            </VerticalStackLayout>

                                                <!-- Row 2: Logo OU nome do programa — agora alinhado ao centro -->
                                                <Grid Grid.Row="2" VerticalOptions="End">
                                                    <ffimageloading:CachedImage
                                                        Source="{Binding LogoUrl}"
                                                        HeightRequest="32"
                                                        WidthRequest="90"
                                                        Aspect="AspectFit"
                                                        HorizontalOptions="Center" 
                                                        VerticalOptions="End"
                                                        IsVisible="{Binding HasLogo}" />

                                                    <Label
                                                        Text="{Binding ProgramName}"
                                                        TextColor="White"
                                                        FontFamily="PoppinsSemibold"
                                                        FontAttributes="Bold"
                                                        FontSize="16"
                                                        HorizontalOptions="Center"
                                                        VerticalOptions="End"
                                                        IsVisible="{Binding ShowProgramName}" />
                                                </Grid>

                                        </Grid>
                                    </AbsoluteLayout>
                                </Border>
                            </ContentView>

                        </DataTemplate>
                    </cards:CardsView.ItemTemplate>
                </cards:CardsView>

                <!-- BLOCO DE TRANSAÇÕES -->
<VerticalStackLayout Margin="0,0,0,0" BackgroundColor="Transparent" Spacing="0">

    <Border BackgroundColor="Transparent" StrokeThickness="0" HeightRequest="32">
        <Border.StrokeShape><RoundRectangle CornerRadius="32,32,0,0" /></Border.StrokeShape>
    </Border>

    <Label x:Name="ExpectedCountLabel" Text="Transações esperadas:"
           Margin="28,0,28,16" TextColor="#1A1A1A"
           FontFamily="PoppinsSemibold" FontAttributes="Bold" FontSize="18" />


        <!-- Lista de transações (simples ou agrupada dependendo do card) -->
    <VerticalStackLayout x:Name="TransactionsList"
        BindableLayout.ItemsSource="{Binding CurrentTransactions}"
        IsVisible="{Binding HasSimpleList}" Spacing="0">
        <BindableLayout.ItemTemplate>
                <DataTemplate x:DataType="local:DashboardTransactionItem">
                    <Grid Margin="24,0,24,12">
                        <!-- O Stroke e StrokeThickness agora reagem ao estado IsOverdue -->
                        <Border BackgroundColor="White" 
                                Stroke="{Binding OverdueBorderColor}" 
                                StrokeThickness="{Binding OverdueThickness}"
                                Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <!-- Sombra aplicada ao Border principal -->
                                <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.1" />
                            </Border.Shadow>

                            <!-- Grid de conteúdo direto, sem a coluna extra de cor -->
                            <Grid Padding="16,14,16,14"
                                ColumnDefinitions="*, Auto"
                                RowDefinitions="Auto, Auto">
                                
                                <Label
                                    Grid.Row="0" Grid.Column="0"
                                    Text="{Binding Description}"
                                    TextColor="#1A1A1A"
                                    FontFamily="PoppinsSemibold"
                                    FontAttributes="Bold"
                                    FontSize="15" />
                                
                                <Label
                                    Grid.Row="0" Grid.Column="1"
                                    Text="{Binding FormattedPoints}"
                                    TextColor="#1A1A1A"
                                    FontFamily="PoppinsSemibold"
                                    FontAttributes="Bold"
                                    FontSize="14"
                                    HorizontalOptions="End" />
                                
                                <Label
                                    Grid.Row="1" Grid.Column="0"
                                    Text="{Binding StoreDisplay}"
                                    TextColor="#6B6B6B"
                                    FontFamily="PoppinsRegular"
                                    FontSize="13" Margin="0,4,0,0" />
                                
                                <Label
                                    Grid.Row="1" Grid.Column="1"
                                    Text="{Binding FormattedDate}"
                                    TextColor="#9E9E9E"
                                    FontFamily="PoppinsRegular"
                                    FontSize="12" HorizontalOptions="End" Margin="0,4,0,0" />
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>    
        </BindableLayout.ItemTemplate>
        </VerticalStackLayout>

<!-- Lista de grupos (usada no card Outros) -->
    <VerticalStackLayout x:Name="GroupedTransactionsList"
        BindableLayout.ItemsSource="{Binding CurrentGroups}"
        Spacing="0" IsVisible="{Binding HasGroups}">
        <BindableLayout.ItemTemplate>
        <DataTemplate x:DataType="local:DashboardTransactionGroup">
            <VerticalStackLayout Spacing="0">
                <Label
                    Text="{Binding GroupName}"
                    Margin="28,8,28,8"
                    TextColor="#6B6B6B"
                    FontFamily="PoppinsSemibold"
                    FontSize="13" />
                <BoxView HeightRequest="1" Color="#E0D8D8" Margin="24,0,24,8" />

                <VerticalStackLayout
                    BindableLayout.ItemsSource="{Binding Transactions}"
                    Spacing="0">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="local:DashboardTransactionItem">
                            <Grid Margin="24,0,24,12">
                                <!-- APLICADO: Bindings de Stroke e StrokeThickness -->
                                <Border BackgroundColor="White" 
                                        Stroke="{Binding OverdueBorderColor}" 
                                        StrokeThickness="{Binding OverdueThickness}" 
                                        Padding="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="16" />
                                    </Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.1" />
                                    </Border.Shadow>

                                    <Grid Padding="16,14,16,14"
                                        ColumnDefinitions="*, Auto"
                                        RowDefinitions="Auto, Auto">
                                        
                                        <Label
                                            Grid.Row="0" Grid.Column="0"
                                            Text="{Binding Description}"
                                            TextColor="#1A1A1A"
                                            FontFamily="PoppinsSemibold"
                                            FontAttributes="Bold"
                                            FontSize="15" />
                                        
                                        <!-- CORRIGIDO: TextColor alterado para #1A1A1A -->
                                        <Label
                                            Grid.Row="0" Grid.Column="1"
                                            Text="{Binding FormattedPoints}"
                                            TextColor="#1A1A1A"
                                            FontFamily="PoppinsSemibold"
                                            FontAttributes="Bold"
                                            FontSize="14"
                                            HorizontalOptions="End" />
                                        
                                        <Label
                                            Grid.Row="1" Grid.Column="0"
                                            Text="{Binding StoreDisplay}"
                                            TextColor="#6B6B6B"
                                            FontFamily="PoppinsRegular"
                                            FontSize="13" Margin="0,4,0,0" />
                                        
                                        <Label
                                            Grid.Row="1" Grid.Column="1"
                                            Text="{Binding FormattedDate}"
                                            TextColor="#9E9E9E"
                                            FontFamily="PoppinsRegular"
                                            FontSize="12" HorizontalOptions="End" Margin="0,4,0,0" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>                    
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </DataTemplate>
    </BindableLayout.ItemTemplate>
</VerticalStackLayout>
    <BoxView HeightRequest="1" Color="#E0D8D8" Margin="24,12,24,12" />

    <Label Text="Ver transações passadas" TextColor="#6B6B6B"
           FontFamily="PoppinsRegular" FontSize="14"
           HorizontalOptions="Center" Margin="0,0,0,24">
        <Label.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnViewPastTransactionsTapped" />
        </Label.GestureRecognizers>
    </Label>

</VerticalStackLayout>             
</VerticalStackLayout>
        </ScrollView>
    
            <controls:BottomNavBar Grid.Row="1" />
    </Grid>
</ContentPage>

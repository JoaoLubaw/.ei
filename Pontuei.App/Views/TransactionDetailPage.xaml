<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Pontuei.App.Views.TransactionDetailPage"
             xmlns:views="clr-namespace:Pontuei.App.Views"
             xmlns:local="clr-namespace:Pontuei.App.Views"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#EDE8E8">

    <ScrollView VerticalScrollBarVisibility="Never" 
                Padding="0,0,0,110">

        <VerticalStackLayout Spacing="0">

            <!-- ── HEADER ──────────────────────────────────────────────── -->
            <Grid Padding="28,56,28,24"
                  ColumnDefinitions="*, Auto">

                <Image Grid.Column="0"
                       Source="logo.svg"
                       HeightRequest="48"
                       WidthRequest="80"
                       HorizontalOptions="Start"
                       VerticalOptions="Center"
                       Aspect="AspectFit" />

                <Border Grid.Column="1" 
                        WidthRequest="40"
                        HeightRequest="40"
                        BackgroundColor="Transparent"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20" />
                    </Border.StrokeShape>
                    <Image Source="settings.svg"
                           WidthRequest="24"
                           HeightRequest="24"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </Grid>

            <!-- ── SEPARADOR ──────────────────────────────────────────── -->
            <BoxView HeightRequest="1" Color="#D0C8C8" Margin="24,0,24,20" />

            <!-- ── TÍTULO + AÇÕES (Visualizar) ────────────────────────── -->
            <Grid Padding="24,0,24,20"
                  ColumnDefinitions="*, Auto, Auto">

                <!-- Título muda conforme modo -->
                <Label x:Name="PageTitleLabel"
                       Grid.Column="0"
                       Text="Criar nova transação"
                       TextColor="#1A1A1A"
                       FontFamily="PoppinsSemibold"
                       FontAttributes="Bold"
                       FontSize="20"
                       VerticalOptions="Center" />

                <!-- Ícone Lixeira — visível só no modo Visualizar -->
                <Border x:Name="DeleteButton"
                        Grid.Column="1"
                        WidthRequest="36"
                        HeightRequest="36"
                        BackgroundColor="Transparent"
                        StrokeThickness="0"
                        IsVisible="False"
                        Margin="0,0,8,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnDeleteTapped" />
                    </Border.GestureRecognizers>
                    <Image Source="trash.svg"
                           WidthRequest="20"
                           HeightRequest="20"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>

                <!-- Ícone Lápis — visível só no modo Visualizar -->
                <Border x:Name="EditButton"
                        Grid.Column="2"
                        WidthRequest="36"
                        HeightRequest="36"
                        BackgroundColor="Transparent"
                        StrokeThickness="0"
                        IsVisible="False">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnEditTapped" />
                    </Border.GestureRecognizers>
                    <Image Source="pen.svg"
                           WidthRequest="20"
                           HeightRequest="20"
                           Aspect="AspectFit"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </Grid>

            <!-- ── FORMULÁRIO ─────────────────────────────────────────── -->
            <VerticalStackLayout Padding="24,0" Spacing="16">

                <!-- DESCRIÇÃO DO ITEM COMPRADO -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="DESCRIÇÃO DE ITEM COMPRADO"
                           TextColor="#9E9E9E"
                           FontFamily="PoppinsSemibold"
                           FontSize="11" />
                    <Border x:Name="DescriptionBorder"
                            BackgroundColor="White"
                            StrokeThickness="0"
                            Padding="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.06" />
                        </Border.Shadow>
                        <Entry x:Name="DescriptionEntry"
                               Text="{Binding Description}"
                               Placeholder="Ex: TV Samsung 55&quot;"
                               PlaceholderColor="#BDBDBD"
                               TextColor="#1A1A1A"
                               FontFamily="PoppinsRegular"
                               FontSize="15"
                               Margin="16,12"
                               IsReadOnly="{Binding IsReadOnly}" />
                    </Border>
                </VerticalStackLayout>

                <!-- LUGAR DE COMPRA -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="LUGAR DE COMPRA"
                           TextColor="#9E9E9E"
                           FontFamily="PoppinsSemibold"
                           FontSize="11" />
                    <Border BackgroundColor="White"
                            StrokeThickness="0"
                            Padding="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.06" />
                        </Border.Shadow>
                        <Entry x:Name="StoreEntry"
                               Text="{Binding Store}"
                               Placeholder="Ex: Casas Bahia"
                               PlaceholderColor="#BDBDBD"
                               TextColor="#1A1A1A"
                               FontFamily="PoppinsRegular"
                               FontSize="15"
                               Margin="16,12"
                               IsReadOnly="{Binding IsReadOnly}" />
                    </Border>
                </VerticalStackLayout>

                <!-- VALOR TOTAL -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="VALOR TOTAL"
                           TextColor="#9E9E9E"
                           FontFamily="PoppinsSemibold"
                           FontSize="11" />
                    <Border BackgroundColor="White"
                            StrokeThickness="0"
                            Padding="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.06" />
                        </Border.Shadow>
                        <Entry x:Name="TotalValueEntry"
                               Text="{Binding FormattedTotalValue}"
                               Placeholder="R$ 0,00"
                               PlaceholderColor="#BDBDBD"
                               TextColor="#1A1A1A"
                               FontFamily="PoppinsRegular"
                               FontSize="15"
                               Keyboard="Numeric"
                               Margin="16,12"
                               IsReadOnly="{Binding IsReadOnly}"
                               TextChanged="OnTotalValueTextChanged" />
                    </Border>
                </VerticalStackLayout>

                <!-- DATA DE COMPRA + DATA DE RECEBIMENTO/RECEBIMENTO DE ITENS -->
                <Grid ColumnDefinitions="*, 16, *" ColumnSpacing="0"> 

                    <!-- DATA DE COMPRA -->
                    <VerticalStackLayout Grid.Column="0" Spacing="6">
                        <Label Text="DATA DE COMPRA"
                               TextColor="#9E9E9E"
                               FontFamily="PoppinsSemibold"
                               FontSize="11" />
                        <Border BackgroundColor="White"
                                StrokeThickness="0"
                                Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.06" />
                            </Border.Shadow>
                            <Grid ColumnDefinitions="*, Auto" Padding="12,10">
                                <Label x:Name="PurchaseDateLabel"
                                       Grid.Column="0"
                                       Text="{Binding FormattedPurchaseDate}"
                                       TextColor="#1A1A1A"
                                       FontFamily="PoppinsRegular"
                                       FontSize="14"
                                       VerticalOptions="Center" />
                                <Image Grid.Column="1"
                                       Source="calendar.svg"
                                       IsVisible="{Binding IsEditable}"
                                       WidthRequest="20"
                                       HeightRequest="20"
                                       Aspect="AspectFit"
                                       VerticalOptions="Center">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnPickPurchaseDateTapped" />
                                    </Image.GestureRecognizers>
                                </Image>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- DATA DE RECEBIMENTO / RECEBIMENTO DE ITENS -->
                    <VerticalStackLayout Grid.Column="2" Spacing="6">
                        <!-- Label muda conforme modo -->
                        <Label x:Name="ReceiptDateLabel"
                               Text="RECEBIMENTO DE ITENS"
                               TextColor="#9E9E9E"
                               FontFamily="PoppinsSemibold"
                               FontSize="11" />
                        <Border BackgroundColor="White"
                                StrokeThickness="0"
                                Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.06" />
                            </Border.Shadow>
                            <Grid ColumnDefinitions="*, Auto" Padding="12,10">
                                <Label x:Name="ReceiptDateValueLabel"
                                       Grid.Column="0"
                                       Text="{Binding FormattedReceiptDate}"
                                       TextColor="#1A1A1A"
                                       FontFamily="PoppinsRegular"
                                       FontSize="14"
                                       VerticalOptions="Center" />
                                <Image Grid.Column="1"
                                       Source="calendar.svg"
                                       IsVisible="{Binding IsEditable}"
                                       WidthRequest="20"
                                       HeightRequest="20"
                                       Aspect="AspectFit"
                                       VerticalOptions="Center">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnPickReceiptDateTapped" />
                                    </Image.GestureRecognizers>
                                </Image>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </Grid>

                <!-- PRAZO DE RECEBIMENTO + PONTUAÇÃO DO DIA -->
                <Grid ColumnDefinitions="*, 16, *" ColumnSpacing="0">

                    <!-- PRAZO DE RECEBIMENTO (stepper) -->
                    <VerticalStackLayout Grid.Column="0" Spacing="6">
                        <Label Text="PRAZO DE RECEBIMENTO"
                               TextColor="#9E9E9E"
                               FontFamily="PoppinsSemibold"
                               FontSize="11" />
                        <Border BackgroundColor="White"
                                StrokeThickness="0"
                                Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.06" />
                            </Border.Shadow>
                            <Grid ColumnDefinitions="Auto, *, Auto" Padding="10,10">
                                <!-- Botão − -->
                                <Label Grid.Column="0"
                                       Text="−"
                                       TextColor="#C0392B"
                                       FontSize="20"
                                       IsVisible="{Binding IsEditable}"
                                       FontFamily="PoppinsSemibold"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center"
                                       WidthRequest="28">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnDeadlineMinus" />
                                    </Label.GestureRecognizers>
                                </Label>

                                <Label Grid.Column="1"
                                       x:Name="DeadlineDaysLabel"
                                       Text="{Binding DeadlineDaysDisplay}"
                                       TextColor="#1A1A1A"
                                       FontFamily="PoppinsRegular"
                                       FontSize="14"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />

                                <!-- Botão + -->
                                <Label Grid.Column="2"
                                       Text="+"
                                       IsVisible="{Binding IsEditable}"
                                       TextColor="#4E8A61"
                                       FontSize="20"
                                       FontFamily="PoppinsSemibold"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center"
                                       WidthRequest="28">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnDeadlinePlus" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- PONTUAÇÃO DO DIA (stepper) -->
                    <VerticalStackLayout Grid.Column="2" Spacing="6">
                        <Label Text="PONTUAÇÃO DO DIA"
                               TextColor="#9E9E9E"
                               FontFamily="PoppinsSemibold"
                               FontSize="11" />
                        <Border BackgroundColor="White"
                                StrokeThickness="0"
                                Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.06" />
                            </Border.Shadow>
                            <Grid ColumnDefinitions="Auto, *, Auto" Padding="10,10">
                                <!-- Botão − -->
                                <Label Grid.Column="0"
                                       Text="−"
                                       TextColor="#C0392B"
                                       IsVisible="{Binding IsEditable}"
                                       FontSize="20"
                                       FontFamily="PoppinsSemibold"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center"
                                       WidthRequest="28">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnPointsMinus" />
                                    </Label.GestureRecognizers>
                                </Label>

                                <Label Grid.Column="1"
                                       x:Name="PointsPerRealLabel"
                                       Text="{Binding PointsPerRealDisplay}"
                                       TextColor="#1A1A1A"
                                       FontFamily="PoppinsRegular"
                                       FontSize="14"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />

                                <!-- Botão + -->
                                <Label Grid.Column="2"
                                       Text="+"
                                       IsVisible="{Binding IsEditable}"
                                       TextColor="#4E8A61"
                                       FontSize="20"
                                       FontFamily="PoppinsSemibold"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center"
                                       WidthRequest="28">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnPointsPlus" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>
                        </Border>

                        <!-- (por real) -->
                        <Label Text="(por real)"
                               TextColor="#9E9E9E"
                               FontFamily="PoppinsRegular"
                               FontSize="11"
                               HorizontalOptions="Center"
                               Margin="0,-4,0,0" />
                    </VerticalStackLayout>
                </Grid>

                <!-- PROGRAMA DE PONTUAÇÃO -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="PROGRAMA DE PONTUAÇÃO"
                           TextColor="#9E9E9E"
                           FontFamily="PoppinsSemibold"
                           FontSize="11" />
                    <Grid ColumnDefinitions="*, Auto">
                        <!-- Seletor de Programa (pílula com gradiente) -->
                        <Border x:Name="ProgramSelectorBorder"
                                Grid.Column="1"
                                HeightRequest="36"
                                StrokeThickness="0"
                                HorizontalOptions="End">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <Border.Background>
                                <LinearGradientBrush x:Name="ProgramGradient" StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop x:Name="ProgramGradientStart" Color="#E4002B" Offset="0.0" />
                                    <GradientStop x:Name="ProgramGradientMid" Color="#B8001F" Offset="0.5" />
                                    <GradientStop x:Name="ProgramGradientEnd" Color="#E4002B" Offset="1.0" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnChangeProgramTapped" />
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Padding="14,0" Spacing="6" VerticalOptions="Center">
                                <Label x:Name="ProgramNameLabel"
                                       Text="Livelo"
                                       TextColor="White"
                                       FontSize="13"
                                       FontFamily="PoppinsSemibold"
                                       VerticalOptions="Center" />
                                <Image Source="change.svg"
                                    IsVisible="{Binding IsEditable}"
                                       WidthRequest="14"
                                       HeightRequest="14"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                <!-- MÍDIAS (pasta) -->
                <VerticalStackLayout Spacing="8" Margin="0,8,0,0">
                    <BoxView HeightRequest="1" Color="#E0D8D8" />

                    <!-- Área de mídias / ícone de pasta -->
                    <Grid HeightRequest="80" HorizontalOptions="Center">
                        <Border WidthRequest="64"
                                HeightRequest="64"
                                BackgroundColor="Transparent"
                                StrokeThickness="0"
                                HorizontalOptions="Center"
                                VerticalOptions="Center">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMediaTapped" />
                            </Border.GestureRecognizers>
                            <Image Source="folder.svg"
                                   WidthRequest="48"
                                   HeightRequest="48"
                                   Aspect="AspectFit"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                    </Grid>

                    <BoxView HeightRequest="1" Color="#E0D8D8" />
                </VerticalStackLayout>

                <!-- ── PAINEL ATUALIZAR STATUS (visível ao tocar em "Atualizar status") ── -->
                <Border x:Name="UpdateStatusPanel"
                        BackgroundColor="White"
                        StrokeThickness="1"
                        Stroke="#E0D8D8"
                        IsVisible="False"
                        Margin="0,8,0,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.08" />
                    </Border.Shadow>

                    <VerticalStackLayout Padding="20,16" Spacing="16">

                        <!-- Campo DATA -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="DATA"
                                   TextColor="#9E9E9E"
                                   FontFamily="PoppinsSemibold"
                                   FontSize="11" />
                            <Border BackgroundColor="#F5F5F5"
                                    StrokeThickness="0"
                                    Padding="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10" />
                                </Border.StrokeShape>
                                <Grid ColumnDefinitions="*, Auto" Padding="12,10">
                                    <Label x:Name="StatusDateLabel"
                                           Grid.Column="0"
                                           Text="{Binding FormattedStatusDate}"
                                           TextColor="#1A1A1A"
                                           FontFamily="PoppinsRegular"
                                           FontSize="14"
                                           VerticalOptions="Center" />
                                    <Image Grid.Column="1"
                                           Source="calendar.svg"
                                           IsVisible="{Binding IsEditable}"
                                           WidthRequest="20"
                                           HeightRequest="20"
                                           Aspect="AspectFit"
                                           VerticalOptions="Center">
                                        <Image.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnPickStatusDateTapped" />
                                        </Image.GestureRecognizers>
                                    </Image>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Botões Contestado / Recebido -->
                        <Grid ColumnDefinitions="*, 12, *">
                            <Border Grid.Column="0"
                                    BackgroundColor="#343a46"
                                    StrokeThickness="0"
                                    HeightRequest="44">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="22" />
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnContestedTapped" />
                                </Border.GestureRecognizers>
                                <Label Text="Contestado"
                                       TextColor="White"
                                       FontFamily="PoppinsSemibold"
                                       FontSize="14"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>

                            <Border Grid.Column="2"
                                    StrokeThickness="0"
                                    HeightRequest="44">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="22" />
                                </Border.StrokeShape>
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                        <GradientStop Color="#4E8A61" Offset="0.0" />
                                        <GradientStop Color="#3A6B4A" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnReceivedTapped" />
                                </Border.GestureRecognizers>
                                <Label Text="Recebido"
                                       TextColor="White"
                                       FontFamily="PoppinsSemibold"
                                       FontSize="14"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- ── BOTÃO ATUALIZAR STATUS (somente modo Visualizar) ── -->
                <Border x:Name="UpdateStatusButton"
                        BackgroundColor="White"
                        StrokeThickness="1.5"
                        Stroke="#D0C8C8"
                        HeightRequest="52"
                        IsVisible="False"
                        Margin="0,8,0,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="26" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.06" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnUpdateStatusTapped" />
                    </Border.GestureRecognizers>
                    <Label Text="Atualizar status"
                           TextColor="#1A1A1A"
                           FontFamily="PoppinsSemibold"
                           FontSize="15"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>

                <!-- ── BOTÕES CANCELAR / SALVAR (modo Criar e Editar) ──── -->
                <Grid x:Name="SaveCancelButtons"
                      ColumnDefinitions="*, 16, *"
                      Margin="0,16,0,0"
                      IsVisible="True">

                    <!-- CANCELAR -->
                    <Border Grid.Column="0"
                            StrokeThickness="0"
                            HeightRequest="52">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="26" />
                        </Border.StrokeShape>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#8B3A3A" Offset="0.0" />
                                <GradientStop Color="#6B2525" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,3" Radius="8" Opacity="0.2" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCancelTapped" />
                        </Border.GestureRecognizers>
                        <Label Text="Cancelar"
                               TextColor="White"
                               FontFamily="PoppinsSemibold"
                               FontSize="15"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>

                    <!-- SALVAR -->
                    <Border Grid.Column="2"
                            StrokeThickness="0"
                            HeightRequest="52">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="26" />
                        </Border.StrokeShape>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#4E8A61" Offset="0.0" />
                                <GradientStop Color="#3A6B4A" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,3" Radius="8" Opacity="0.2" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSaveTapped" />
                        </Border.GestureRecognizers>
                        <Label Text="Salvar"
                               TextColor="White"
                               FontFamily="PoppinsSemibold"
                               FontSize="15"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                </Grid>

            </VerticalStackLayout>
            <!-- ── FIM FORMULÁRIO ─────────────────────────────────────── -->

        </VerticalStackLayout>
    </ScrollView>

</views:BasePage>

<?xml version="1.0" encoding="utf-8" ?>
<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Pontuei.App.Views.SettingsPage"
             xmlns:views="clr-namespace:Pontuei.App.Views"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#EDE8E8">

    <ScrollView VerticalScrollBarVisibility="Never" Padding="0,0,0,110">
        <VerticalStackLayout Spacing="0" Padding="24">

            <!-- ── SEÇÃO: INFORMAÇÕES DE CONTA ── -->
            <Label Text="Informações de conta" TextColor="#1A1A1A" FontSize="20" FontFamily="PoppinsSemibold" />
            <BoxView HeightRequest="1" Color="#C5C2BC" Margin="0,4,0,24" />

            <!-- CAMPO: NOME -->
            <Border HeightRequest="54" Stroke="#3f3838" StrokeThickness="2" BackgroundColor="White" Margin="0,0,0,12">
                <Border.StrokeShape><RoundRectangle CornerRadius="27" /></Border.StrokeShape>
                <Grid ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
                    <Border Grid.Column="0" WidthRequest="36" HeightRequest="36" BackgroundColor="#3f3838" StrokeThickness="0" Margin="8,0,0,0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                        <Image Source="profile_white.svg" WidthRequest="18" HeightRequest="18" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <Entry Grid.Column="1" x:Name="NameEntry" Text="{Binding UserName}" IsReadOnly="{Binding IsNameReadOnly}" TextColor="#1A1A1A" FontFamily="PoppinsRegular" FontSize="14" Margin="12,0" VerticalOptions="Center" />
                    
                    <!-- Ícones de Ação Inline (Nome) -->
                    <HorizontalStackLayout Grid.Column="2" Margin="0,0,12,0" Spacing="8" VerticalOptions="Center">
                        <Image Source="cancel.svg" WidthRequest="24" HeightRequest="24" IsVisible="{Binding IsNameEditing}">
                            <Image.GestureRecognizers><TapGestureRecognizer Tapped="OnCancelNameEditTapped" /></Image.GestureRecognizers>
                        </Image>
                        <Image Source="confirm.svg" WidthRequest="24" HeightRequest="24" IsVisible="{Binding IsNameEditing}">
                            <Image.GestureRecognizers><TapGestureRecognizer Tapped="OnConfirmNameEditTapped" /></Image.GestureRecognizers>
                        </Image>
                        <Image Source="pen.svg" WidthRequest="18" HeightRequest="18" IsVisible="{Binding IsNameReadOnly}">
                            <Image.GestureRecognizers><TapGestureRecognizer Tapped="OnEnableNameEditTapped" /></Image.GestureRecognizers>
                        </Image>
                    </HorizontalStackLayout>
                </Grid>
            </Border>

            <!-- CAMPO: E-MAIL -->
            <Border HeightRequest="54" Stroke="#3f3838" StrokeThickness="2" BackgroundColor="White" Margin="0,0,0,12">
                <Border.StrokeShape><RoundRectangle CornerRadius="27" /></Border.StrokeShape>
                <Grid ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
                    <Border Grid.Column="0" WidthRequest="36" HeightRequest="36" BackgroundColor="#3f3838" StrokeThickness="0" Margin="8,0,0,0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="18" /></Border.StrokeShape>
                        <Image Source="email_white.svg" WidthRequest="18" HeightRequest="18" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <Entry Grid.Column="1" x:Name="EmailEntry" Text="{Binding UserEmail}" IsReadOnly="{Binding IsEmailReadOnly}" Keyboard="Email" TextColor="#1A1A1A" FontFamily="PoppinsRegular" FontSize="14" Margin="12,0" VerticalOptions="Center" />
                    
                    <!-- Ícones de Ação Inline (E-mail) -->
                    <HorizontalStackLayout Grid.Column="2" Margin="0,0,12,0" Spacing="8" VerticalOptions="Center">
                        <Image Source="cancel.svg" WidthRequest="24" HeightRequest="24" IsVisible="{Binding IsEmailEditing}">
                            <Image.GestureRecognizers><TapGestureRecognizer Tapped="OnCancelEmailEditTapped" /></Image.GestureRecognizers>
                        </Image>
                        <Image Source="confirm.svg" WidthRequest="24" HeightRequest="24" IsVisible="{Binding IsEmailEditing}">
                            <Image.GestureRecognizers><TapGestureRecognizer Tapped="OnConfirmEmailEditTapped" /></Image.GestureRecognizers>
                        </Image>
                        <Image Source="pen.svg" WidthRequest="18" HeightRequest="18" IsVisible="{Binding IsEmailReadOnly}">
                            <Image.GestureRecognizers><TapGestureRecognizer Tapped="OnEnableEmailEditTapped" /></Image.GestureRecognizers>
                        </Image>
                    </HorizontalStackLayout>
                </Grid>
            </Border>

            <!-- Alerta Amarelo de E-mail Não Verificado -->
            <Border x:Name="UnverifiedEmailCard" BackgroundColor="#FFF3CD" StrokeThickness="0" Margin="4,0,4,12">
                <Border.StrokeShape><RoundRectangle CornerRadius="12" /></Border.StrokeShape>
                <Grid ColumnDefinitions="*, Auto" Padding="14,10">
                    <Label Grid.Column="0" Text="Seu e-mail ainda não foi verificado." TextColor="#856404" FontSize="12" FontFamily="PoppinsRegular" VerticalOptions="Center" />
                    <Button Grid.Column="1" Text="Verificar agora" BackgroundColor="#856404" TextColor="White" FontSize="11" HeightRequest="32" Padding="10,0" CornerRadius="16" Clicked="OnVerifyCurrentEmailClicked" />
                </Grid>
            </Border>

            <!-- ── PAINEL EXPANSIVO: VERIFICAR E-MAIL ── -->
            <VerticalStackLayout x:Name="VerifyEmailPanel" IsVisible="False" Opacity="0" Spacing="10" Margin="4,0,4,16">
                <Label Text="Enviamos um código de 6 dígitos para o seu e-mail:" TextColor="#6B6B6B" FontFamily="PoppinsRegular" FontSize="12" />
                
                <Border HeightRequest="48" BackgroundColor="#3f3838" StrokeThickness="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="24" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
                        <Image Grid.Column="0" Source="lock.svg" WidthRequest="16" Margin="14,0,0,0" />
                        <Entry Grid.Column="1" x:Name="EmailCodeEntry" Placeholder="Código numérico" Keyboard="Numeric" MaxLength="6" PlaceholderColor="#9E9E9E" TextColor="White" FontFamily="PoppinsRegular" FontSize="13" Margin="10,0" VerticalOptions="Center" />
                    </Grid>
                </Border>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="12" Margin="0,6,0,0">
                    <Button Grid.Column="0" Text="Cancelar" BackgroundColor="#965D5C" TextColor="White" HeightRequest="40" CornerRadius="20" Clicked="OnCancelVerifyEmailClicked"/>
                    <Button Grid.Column="1" Text="Verificar código" BackgroundColor="#528F65" TextColor="White" HeightRequest="40" CornerRadius="20" Clicked="OnSubmitVerifyEmailClicked"/>
                </Grid>
            </VerticalStackLayout>

            <!-- BOTÃO ALTERAR SENHA -->
            <Button Text="Alterar senha"
                    FontFamily="PoppinsSemibold"
                    FontSize="14"
                    TextColor="White"
                    BackgroundColor="{Binding AlterarSenhaButtonColor}"
                    CornerRadius="20"
                    HeightRequest="40"
                    HorizontalOptions="Center"
                    WidthRequest="180"
                    Margin="0,8,0,16"
                    Clicked="OnToggleChangePasswordClicked" />

            <!-- ── PAINEL EXPANSIVO: FORMULÁRIO DE TROCA DE SENHA ── -->
            <VerticalStackLayout x:Name="ChangePasswordPanel" IsVisible="False" Opacity="0" Spacing="10" Margin="4,0,4,16">
                <!-- Senha Atual -->
                <Border HeightRequest="48" BackgroundColor="#3f3838" StrokeThickness="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="24" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
                        <Image Grid.Column="0" Source="key_white.svg" WidthRequest="16" Margin="14,0,0,0" />
                        <Entry Grid.Column="1" x:Name="CurrentPasswordEntry" Placeholder="Senha atual" IsPassword="True" PlaceholderColor="#9E9E9E" TextColor="White" FontFamily="PoppinsRegular" FontSize="13" Margin="10,0" VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Nova Senha -->
                <Border HeightRequest="48" BackgroundColor="#3f3838" StrokeThickness="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="24" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
                        <Image Grid.Column="0" Source="key_white.svg" WidthRequest="16" Margin="14,0,0,0" />
                        <Entry Grid.Column="1" x:Name="NewPasswordEntry" Placeholder="Nova senha" IsPassword="True" PlaceholderColor="#9E9E9E" TextColor="White" FontFamily="PoppinsRegular" FontSize="13" Margin="10,0" VerticalOptions="Center" TextChanged="OnNewPasswordChanged" />
                    </Grid>
                </Border>

                <!-- Checklist de Regras da Senha -->
                <VerticalStackLayout Padding="10,4" Spacing="2">
                    <Label x:Name="RuleLength"   Text="• No mínimo 8 dígitos."           TextColor="#9E9E9E" FontFamily="PoppinsRegular" FontSize="12" />
                    <Label x:Name="RuleUpper"    Text="• Pelo menos 1 letra maiúscula."  TextColor="#9E9E9E" FontFamily="PoppinsRegular" FontSize="12" />
                    <Label x:Name="RuleLower"    Text="• Pelo menos 1 letra minúscula."  TextColor="#9E9E9E" FontFamily="PoppinsRegular" FontSize="12" />
                    <Label x:Name="RuleNumber"   Text="• Pelo menos 1 número."           TextColor="#9E9E9E" FontFamily="PoppinsRegular" FontSize="12" />
                    <Label x:Name="RuleSpecial"  Text="• Pelo menos 1 caractere especial." TextColor="#9E9E9E" FontFamily="PoppinsRegular" FontSize="12" />
                </VerticalStackLayout>

                <!-- Confirmar Nova Senha -->
                <Border HeightRequest="48" BackgroundColor="#3f3838" StrokeThickness="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="24" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">
                        <Image Grid.Column="0" Source="key_hole_white.svg" WidthRequest="16" Margin="14,0,0,0" />
                        <Entry Grid.Column="1" x:Name="ConfirmPasswordEntry" Placeholder="Confirme a nova senha" IsPassword="True" PlaceholderColor="#9E9E9E" TextColor="White" FontFamily="PoppinsRegular" FontSize="13" Margin="10,0" VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Botões do Painel de Senha -->
                <Grid ColumnDefinitions="*, *" ColumnSpacing="12" Margin="0,6,0,0">
                    <Button Grid.Column="0" Text="Cancelar" BackgroundColor="#965D5C" TextColor="White" HeightRequest="40" CornerRadius="20" Clicked="OnToggleChangePasswordClicked"/>
                    <Button Grid.Column="1" Text="Salvar Senha" BackgroundColor="#528F65" TextColor="White" HeightRequest="40" CornerRadius="20" Clicked="OnSaveNewPasswordClicked"/>
                </Grid>
            </VerticalStackLayout>

            <!-- ── SEÇÃO: NOTIFICAÇÕES ── -->
            <Label Text="Notificações" TextColor="#1A1A1A" FontSize="20" FontFamily="PoppinsSemibold" />
            <BoxView HeightRequest="1" Color="#C5C2BC" Margin="0,4,0,16" />

            <Grid ColumnDefinitions="Auto,*" Margin="0,4,0,8" ColumnSpacing="10" VerticalOptions="Center">
                <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnPushNotificationTapped" /></Grid.GestureRecognizers>
                <Border Grid.Column="0" x:Name="PushCheckBorder" WidthRequest="22" HeightRequest="22" BackgroundColor="Transparent" Stroke="#3A6B4A" StrokeThickness="2">
                    <Border.StrokeShape><RoundRectangle CornerRadius="4" /></Border.StrokeShape>
                    <Label x:Name="PushCheckMark" Text="✓" TextColor="#3A6B4A" FontSize="13" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="False" />
                </Border>
                <Label Grid.Column="1" Text="Notificações Push" TextColor="#1A1A1A" FontFamily="PoppinsRegular" FontSize="14" VerticalOptions="Center" />
            </Grid>

            <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,32" ColumnSpacing="10" VerticalOptions="Center">
                <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnEmailNotificationTapped" /></Grid.GestureRecognizers>
                <Border Grid.Column="0" x:Name="EmailCheckBorder" WidthRequest="22" HeightRequest="22" BackgroundColor="Transparent" Stroke="#3A6B4A" StrokeThickness="2">
                    <Border.StrokeShape><RoundRectangle CornerRadius="4" /></Border.StrokeShape>
                    <Label x:Name="EmailCheckMark" Text="✓" TextColor="#3A6B4A" FontSize="13" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="False" />
                </Border>
                <Label Grid.Column="1" Text="Notificações no Email" TextColor="#1A1A1A" FontFamily="PoppinsRegular" FontSize="14" VerticalOptions="Center" />
            </Grid>

            <!-- BOTÃO: DELETAR CONTA (Agora acima do botão Sair) -->
            <Button Text="Deletar conta" FontFamily="PoppinsSemibold" FontSize="14" TextColor="White" BackgroundColor="#BA1A1A" CornerRadius="20" HeightRequest="40" HorizontalOptions="Center" WidthRequest="220" Margin="0,0,0,24" Clicked="OnDeleteAccountClicked" />

            <!-- BOTÃO: SAIR -->
            <Button Text="Sair" FontFamily="PoppinsSemibold" FontSize="15" TextColor="White" BackgroundColor="#3f3838" CornerRadius="26" HeightRequest="52" Clicked="OnLogoutClicked" />

        </VerticalStackLayout>
    </ScrollView>
</views:BasePage>
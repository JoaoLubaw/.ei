<Shell
    x:Class="Pontuei.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Pontuei.App.Views"
    Shell.FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False">

    <!-- Tab group principal: Home e Notifications são irmãs.
         A troca entre elas não usa push/pop, então o footer do BasePage
         fica completamente estático — não entra na animação do Shell. -->
<!-- Adicione Shell.TabBarIsVisible="False" no seu TabBar -->
    <TabBar Shell.NavBarIsVisible="False" Shell.TabBarIsVisible="False">
        <Tab>
            <ShellContent
                Route="home"
                ContentTemplate="{DataTemplate views:HomePage}"
                Shell.NavBarIsVisible="False" />
        </Tab>

        <Tab>
            <ShellContent
                Route="history"
                ContentTemplate="{DataTemplate views:HistoryPage}"
                Shell.NavBarIsVisible="False" />
        </Tab>
        
        <Tab>
            <ShellContent
                Route="notifications"
                ContentTemplate="{DataTemplate views:NotificationsPage}"
                Shell.NavBarIsVisible="False" />
        </Tab>
    </TabBar>
    
    <!-- Auth flow — acessíveis via GoToAsync("//auth") etc quando necessário -->
    <ShellContent
        Route="splash"
        ContentTemplate="{DataTemplate views:SplashPage}"
        Shell.NavBarIsVisible="False" />

    <ShellContent
        Route="auth"
        ContentTemplate="{DataTemplate views:AuthPage}"
        Shell.NavBarIsVisible="False" />

</Shell>

<Shell
    x:Class="Pontuei.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Pontuei.App.Views"
    Shell.FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False">

    <!-- 1. SPLASH PAGE NO TOPO: O app sempre abrirá aqui primeiro para avaliar o login -->
    <ShellContent
        Route="splash"
        ContentTemplate="{DataTemplate views:SplashPage}"
        Shell.NavBarIsVisible="False" />

    <!-- 2. TAB BAR: Para onde o usuário vai se ESTIVER logado -->
    <TabBar Shell.NavBarIsVisible="False" Shell.TabBarIsVisible="False">
        <Tab>
            <ShellContent
                Route="home"
                ContentTemplate="{DataTemplate views:HomePage}"
                Shell.NavBarIsVisible="False" />
        </Tab>

        <Tab>
            <ShellContent
                Route="history"
                ContentTemplate="{DataTemplate views:HistoryPage}"
                Shell.NavBarIsVisible="False" />
        </Tab>
        
        <Tab>
            <ShellContent
                Route="notifications"
                ContentTemplate="{DataTemplate views:NotificationsPage}"
                Shell.NavBarIsVisible="False" />
        </Tab>
    </TabBar>
    
    <!-- 3. ROTA DE AUTH: Para onde o usuário vai se NÃO ESTIVER logado (após clicar em "Bora começar") -->
    <ShellContent
        Route="auth"
        ContentTemplate="{DataTemplate views:AuthPage}"
        Shell.NavBarIsVisible="False" />

</Shell>
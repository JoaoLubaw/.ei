<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Pontuei.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Pontuei.App.Views"
    Shell.FlyoutBehavior="Disabled"
    Shell.TabBarBackgroundColor="#E9E2E2"
    Shell.TabBarForegroundColor="#3A6B4A"
    Shell.TabBarUnselectedColor="#9E9E9E">

    <!-- Initial Screen: Splash -->
    <ShellContent
        x:Name="SplashContent"
        Route="splash"
        ContentTemplate="{DataTemplate views:SplashPage}"
        Shell.NavBarIsVisible="False" />

    <ShellContent
        Route="auth"
        ContentTemplate="{DataTemplate views:AuthPage}"
        Shell.NavBarIsVisible="False" />

    <!-- Fluxo principal com tab bar -->
    <TabBar Route="main">
        <ShellContent
            Title="Início"
            Icon="clock.svg"
            Route="home"
            ContentTemplate="{DataTemplate views:HomePage}"
            Shell.NavBarIsVisible="False" />
    </TabBar>

</Shell>

<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- =========================================================
         Global Styles for .Ei App
         ========================================================= -->

    <!-- Main green button -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryGreen}" />
        <Setter Property="TextColor" Value="{StaticResource TextOnPrimary}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="30" />
        <Setter Property="HeightRequest" Value="56" />
        <Setter Property="Padding" Value="24,0" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{StaticResource PrimaryGreenDark}" Offset="0,4" Radius="12" Opacity="0.3" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Secondary button (outline) -->
    <Style x:Key="OutlineButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource TextAccentGreen}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="30" />
        <Setter Property="HeightRequest" Value="56" />
        <Setter Property="BorderColor" Value="{StaticResource PrimaryGreen}" />
        <Setter Property="BorderWidth" Value="1.5" />
    </Style>

    <!-- Danger button (delete) -->
    <Style x:Key="DangerButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource DangerRed}" />
        <Setter Property="TextColor" Value="{StaticResource TextOnPrimary}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="30" />
        <Setter Property="HeightRequest" Value="56" />
    </Style>

    <!-- Cancel button (brownish-red like in the mockup) -->
    <Style x:Key="CancelButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="#8B3A3A" />
        <Setter Property="TextColor" Value="{StaticResource TextOnPrimary}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="30" />
        <Setter Property="HeightRequest" Value="56" />
    </Style>

    <!-- Dark Input field -->
    <Style x:Key="DarkEntry" TargetType="Entry">
        <Setter Property="BackgroundColor" Value="{StaticResource InputBackground}" />
        <Setter Property="TextColor" Value="{StaticResource InputText}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource InputPlaceholder}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="HeightRequest" Value="52" />
        <Setter Property="Margin" Value="0" />
    </Style>

    <!-- Light Input field (in internal screens) -->
    <Style x:Key="LightEntry" TargetType="Entry">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceWhite}" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextMuted}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="HeightRequest" Value="52" />
    </Style>

    <!-- Title label from section -->
    <Style x:Key="SectionTitle" TargetType="Label">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <!-- Subtitle label -->
    <Style x:Key="SubtitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="LineHeight" Value="1.4" />
    </Style>

    <!-- green link label -->
    <Style x:Key="LinkLabel" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource TextAccentGreen}" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <!-- generic card -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceWhite}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 16" />
        <Setter Property="Stroke" Value="{StaticResource BorderLight}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="#000000" Offset="0,2" Radius="8" Opacity="0.06" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Transaction Card with colored left border (applied via code) -->
    <Style x:Key="TransactionCard" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceWhite}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        <Setter Property="Stroke" Value="{StaticResource BorderLight}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

</ResourceDictionary>

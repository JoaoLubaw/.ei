<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- =========================================================
         .Ei — Principal Collection of Colors
         ========================================================= -->

    <!-- Main background color -->
    <Color x:Key="AppBackground">#e9e2e2</Color>

    <!-- Surfaces -->
    <Color x:Key="SurfaceWhite">#FFFFFF</Color>
    <Color x:Key="SurfaceCard">#F5F3EF</Color>

    <!-- Main green colors -->
    <Color x:Key="PrimaryGreen">#3A6B4A</Color>
    <Color x:Key="PrimaryGreenLight">#4E8A61</Color>
    <Color x:Key="PrimaryGreenDark">#2A5138</Color>

    <!-- Header gradient (dark background → green) -->
    <Color x:Key="HeaderDark">#1A1A1A</Color>
    <Color x:Key="HeaderGreenMid">#2D5C3F</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#1A1A1A</Color>
    <Color x:Key="TextSecondary">#6B6B6B</Color>
    <Color x:Key="TextMuted">#9E9E9E</Color>
    <Color x:Key="TextOnPrimary">#FFFFFF</Color>
    <Color x:Key="TextAccentGreen">#3A6B4A</Color>

    <!-- Transaction Status -->
    <Color x:Key="DangerRed">#E53935</Color>
    <Color x:Key="DangerRedLight">#FFEBEE</Color>
    <Color x:Key="SuccessGreen">#43A047</Color>
    <Color x:Key="SuccessGreenLight">#E8F5E9</Color>
    <Color x:Key="WarningAmber">#FB8C00</Color>

    <!-- Borders -->
    <Color x:Key="BorderLight">#E0DDD8</Color>
    <Color x:Key="BorderMedium">#C5C2BC</Color>

    <!-- Input fields -->
    <Color x:Key="InputBackground">#3f3838</Color>
    <Color x:Key="InputText">#FFFFFF</Color>
    <Color x:Key="InputPlaceholder">#9E9E9E</Color>

</ResourceDictionary>
